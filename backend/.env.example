# Copy this file to .env and update values for your environment.

# Django core
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS origins allowed to call the API
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Clerk JWT verification settings
# Replace your-clerk-frontend-api-slug with your actual Clerk frontend API slug.
CLERK_ISSUER=https://your-clerk-frontend-api-slug.clerk.accounts.dev
CLERK_JWKS_URL=https://your-clerk-frontend-api-slug.clerk.accounts.dev/.well-known/jwks.json
# Optional: set if your JWT template uses a specific audience claim.
CLERK_AUDIENCE=

# Optional but recommended for syncing username/email from Clerk into Django users.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
CLERK_API_URL=https://api.clerk.com/v1
